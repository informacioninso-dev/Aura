AURA_ENV=production
DJANGO_DEBUG=0
DJANGO_SECRET_KEY=REEMPLAZAR_CON_CLAVE_SECRETA_GENERADA
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,tu-dominio.com
DJANGO_TIME_ZONE=America/Santiago

DB_ENGINE=django.db.backends.postgresql
DB_NAME=REEMPLAZAR_CON_NOMBRE_DB
DB_USER=REEMPLAZAR_CON_USUARIO_DB
DB_PASSWORD=REEMPLAZAR_CON_PASSWORD_DB
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=120

DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1
DJANGO_CSRF_TRUSTED_ORIGINS=https://tu-dominio.com
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=1
DJANGO_SECURE_HSTS_PRELOAD=1

DJANGO_CORS_ALLOWED_ORIGINS=https://tu-dominio.com
DJANGO_RATE_AUTH_LOGIN=12/min
DJANGO_RATE_AUTH_REGISTER=20/min
DJANGO_RATE_AUTH_PASSWORD_RECOVERY=8/min
DJANGO_RATE_AUTH_PASSWORD_CHANGE=20/min
DJANGO_RATE_SUPERADMIN_OPS=120/min

# Email (SMTP) — reemplaza con los datos de tu proveedor (Brevo, SendGrid, etc.)
DJANGO_DEFAULT_FROM_EMAIL=no-reply@tu-dominio.com
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=REEMPLAZAR_CON_HOST_SMTP
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=REEMPLAZAR_CON_USUARIO_SMTP
DJANGO_EMAIL_HOST_PASSWORD=REEMPLAZAR_CON_PASSWORD_SMTP
DJANGO_EMAIL_USE_TLS=1
DJANGO_EMAIL_USE_SSL=0
DJANGO_EMAIL_TIMEOUT=20
DJANGO_EMAIL_SUBJECT_PREFIX=[Aura]
DJANGO_EMAIL_ENCRYPTION_KEY=REEMPLAZAR_CON_PASSPHRASE_LARGA_Y_UNICA
